#!/usr/bin/env bash
set -euo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Default options
BUILD_MODE=false
RELEASE_MODE=false

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --build|-b)
            BUILD_MODE=true
            shift
            ;;
        --release|-r)
            RELEASE_MODE=true
            shift
            ;;
        --help|-h)
            echo "Usage: $0 [OPTIONS]"
            echo ""
            echo "Options:"
            echo "  --build, -b     Build mode: run 'cargo build' instead of 'cargo check'"
            echo "  --release, -r   Release mode: use --release flag for cargo commands"
            echo "  --help, -h      Show this help message"
            echo ""
            echo "By default, runs in check mode (cargo check) with debug profile."
            exit 0
            ;;
        *)
            echo -e "${RED}Unknown option: $1${NC}"
            echo "Use --help for usage information."
            exit 1
            ;;
    esac
done

# Navigate to repo root
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR/.."

# Build cargo flags
CARGO_FLAGS=""
if [[ "$RELEASE_MODE" == true ]]; then
    CARGO_FLAGS="--release"
fi

# Determine mode description
if [[ "$BUILD_MODE" == true ]]; then
    MODE_DESC="build"
    CARGO_CMD="cargo build"
else
    MODE_DESC="check"
    CARGO_CMD="cargo check"
fi

if [[ "$RELEASE_MODE" == true ]]; then
    MODE_DESC="$MODE_DESC (release)"
else
    MODE_DESC="$MODE_DESC (debug)"
fi

echo -e "${YELLOW}Running checks in ${MODE_DESC} mode...${NC}"
echo ""

# Step 1: Format check
echo -e "${YELLOW}[1/4] Checking formatting...${NC}"
if cargo fmt --check; then
    echo -e "${GREEN}  Formatting OK${NC}"
else
    echo -e "${RED}  Formatting failed. Run 'cargo fmt' to fix.${NC}"
    exit 1
fi
echo ""

# Step 2: Clippy lints
echo -e "${YELLOW}[2/4] Running clippy...${NC}"
if cargo clippy $CARGO_FLAGS -- -D warnings; then
    echo -e "${GREEN}  Clippy OK${NC}"
else
    echo -e "${RED}  Clippy found issues.${NC}"
    exit 1
fi
echo ""

# Step 3: Check or Build
if [[ "$BUILD_MODE" == true ]]; then
    echo -e "${YELLOW}[3/4] Building...${NC}"
else
    echo -e "${YELLOW}[3/4] Checking...${NC}"
fi
if RUSTFLAGS="-D warnings" $CARGO_CMD $CARGO_FLAGS; then
    if [[ "$BUILD_MODE" == true ]]; then
        echo -e "${GREEN}  Build OK${NC}"
    else
        echo -e "${GREEN}  Check OK${NC}"
    fi
else
    if [[ "$BUILD_MODE" == true ]]; then
        echo -e "${RED}  Build failed.${NC}"
    else
        echo -e "${RED}  Check failed.${NC}"
    fi
    exit 1
fi
echo ""

# Step 4: Tests
echo -e "${YELLOW}[4/4] Running tests...${NC}"
if RUSTFLAGS="-D warnings" cargo test $CARGO_FLAGS; then
    echo -e "${GREEN}  Tests OK${NC}"
else
    echo -e "${RED}  Tests failed.${NC}"
    exit 1
fi
echo ""

echo -e "${GREEN}All checks passed!${NC}"
