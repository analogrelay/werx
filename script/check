#!/usr/bin/env bash
set -euo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Navigate to repo root
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR/.."

echo -e "${YELLOW}Running pre-commit checks...${NC}"
echo ""

# Step 1: Format check
echo -e "${YELLOW}[1/4] Checking formatting...${NC}"
if cargo fmt --check; then
    echo -e "${GREEN}  Formatting OK${NC}"
else
    echo -e "${RED}  Formatting failed. Run 'cargo fmt' to fix.${NC}"
    exit 1
fi
echo ""

# Step 2: Clippy lints
echo -e "${YELLOW}[2/4] Running clippy...${NC}"
if cargo clippy -- -D warnings; then
    echo -e "${GREEN}  Clippy OK${NC}"
else
    echo -e "${RED}  Clippy found issues.${NC}"
    exit 1
fi
echo ""

# Step 3: Build with warnings as errors
echo -e "${YELLOW}[3/4] Building...${NC}"
if RUSTFLAGS="-D warnings" cargo build; then
    echo -e "${GREEN}  Build OK${NC}"
else
    echo -e "${RED}  Build failed.${NC}"
    exit 1
fi
echo ""

# Step 4: Tests with warnings as errors
echo -e "${YELLOW}[4/4] Running tests...${NC}"
if RUSTFLAGS="-D warnings" cargo test; then
    echo -e "${GREEN}  Tests OK${NC}"
else
    echo -e "${RED}  Tests failed.${NC}"
    exit 1
fi
echo ""

echo -e "${GREEN}All checks passed!${NC}"
