#!/usr/bin/env bash
set -euo pipefail

# Navigate to repo root
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR/../.."

CARGO_TOML="Cargo.toml"

if [[ ! -f "$CARGO_TOML" ]]; then
    echo "Error: $CARGO_TOML not found" >&2
    exit 1
fi

# Extract current version from Cargo.toml
CURRENT_VERSION=$(grep -m1 '^version = ' "$CARGO_TOML" | sed -E 's/version = "([0-9]+\.[0-9]+\.[0-9]+)"/\1/')

if [[ -z "$CURRENT_VERSION" ]]; then
    echo "Error: Could not extract version from $CARGO_TOML" >&2
    exit 1
fi

# Calculate next patch version
IFS='.' read -r MAJOR MINOR PATCH <<< "$CURRENT_VERSION"
NEXT_VERSION="$MAJOR.$MINOR.$((PATCH + 1))"

# Update Cargo.toml
sed -i.bak -E "s/^version = \"$CURRENT_VERSION\"/version = \"$NEXT_VERSION\"/" "$CARGO_TOML"
rm -f "$CARGO_TOML.bak"

echo "Bumped version: $CURRENT_VERSION -> $NEXT_VERSION"
