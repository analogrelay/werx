#!/usr/bin/env bash
set -euo pipefail

# Navigate to repo root
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR/../.."

CHANGELOG="CHANGELOG.md"
CHECK_MODE=false
RELEASE_DATE=""

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --check)
            CHECK_MODE=true
            shift
            ;;
        *)
            RELEASE_DATE="$1"
            shift
            ;;
    esac
done

# Default to today's date if not provided
if [[ -z "$RELEASE_DATE" ]]; then
    RELEASE_DATE=$(date +%Y-%m-%d)
fi

# Read the changelog
if [[ ! -f "$CHANGELOG" ]]; then
    echo "Error: $CHANGELOG not found" >&2
    exit 1
fi

# Extract the current top version line
TOP_VERSION_LINE=$(grep -m1 '^## ' "$CHANGELOG")

if [[ "$CHECK_MODE" == "true" ]]; then
    # Check mode: verify changelog is marked (has date, not "Unreleased")
    if echo "$TOP_VERSION_LINE" | grep -q "(Unreleased)"; then
        echo "Error: Changelog not marked for release. Top version is still 'Unreleased'." >&2
        echo "Run 'script/helpers/mark-release' to mark the release." >&2
        exit 1
    fi
    echo "Changelog is marked for release."
    exit 0
fi

# Extract version number from top entry
VERSION=$(echo "$TOP_VERSION_LINE" | sed -E 's/^## ([0-9]+\.[0-9]+\.[0-9]+).*/\1/')

if [[ -z "$VERSION" ]]; then
    echo "Error: Could not extract version number from changelog" >&2
    exit 1
fi

# Check if already released
if ! echo "$TOP_VERSION_LINE" | grep -q "(Unreleased)"; then
    echo "Error: Top version is already released (not 'Unreleased')" >&2
    exit 1
fi

# Calculate next patch version
IFS='.' read -r MAJOR MINOR PATCH <<< "$VERSION"
NEXT_VERSION="$MAJOR.$MINOR.$((PATCH + 1))"

# Create the new changelog content
{
    # Header
    echo "# Release History"
    echo ""
    
    # New unreleased entry
    echo "## $NEXT_VERSION (Unreleased)"
    echo ""
    echo "### Features Added"
    echo ""
    echo "### Breaking Changes"
    echo ""
    echo "### Bugs Fixed"
    echo ""
    echo "### Other Changes"
    echo ""
    
    # Process the rest of the file
    IN_TOP_VERSION=false
    CURRENT_SECTION=""
    SECTION_HAS_CONTENT=false
    PENDING_SECTION=""
    FIRST_VERSION=true
    
    while IFS= read -r line; do
        # Skip the file header
        if [[ "$line" == "# Release History" ]]; then
            continue
        fi
        
        # Detect version headers
        if [[ "$line" =~ ^##\ [0-9]+\.[0-9]+\.[0-9]+ ]]; then
            # Output any pending section from previous version
            if [[ -n "$PENDING_SECTION" ]] && [[ "$SECTION_HAS_CONTENT" == "true" ]]; then
                echo "$PENDING_SECTION"
                echo ""
            fi
            
            if [[ "$FIRST_VERSION" == "true" ]]; then
                # This is the top version - mark it with the release date
                echo "## $VERSION ($RELEASE_DATE)"
                echo ""
                IN_TOP_VERSION=true
                FIRST_VERSION=false
            else
                IN_TOP_VERSION=false
                echo "$line"
            fi
            CURRENT_SECTION=""
            SECTION_HAS_CONTENT=false
            PENDING_SECTION=""
            continue
        fi
        
        # Detect section headers
        if [[ "$line" =~ ^###\  ]]; then
            # Output pending section if it had content
            if [[ -n "$PENDING_SECTION" ]] && [[ "$SECTION_HAS_CONTENT" == "true" ]]; then
                echo "$PENDING_SECTION"
                echo ""
            fi
            
            if [[ "$IN_TOP_VERSION" == "true" ]]; then
                # For the top version, defer section output until we know if it has content
                PENDING_SECTION="$line"
                SECTION_HAS_CONTENT=false
            else
                echo "$line"
            fi
            continue
        fi
        
        # Check for content (non-empty, non-whitespace lines)
        if [[ -n "${line// /}" ]] && [[ ! "$line" =~ ^# ]]; then
            if [[ "$IN_TOP_VERSION" == "true" ]] && [[ -n "$PENDING_SECTION" ]]; then
                SECTION_HAS_CONTENT=true
            fi
        fi
        
        # Output the line
        if [[ "$IN_TOP_VERSION" == "true" ]]; then
            if [[ -n "$PENDING_SECTION" ]]; then
                if [[ "$SECTION_HAS_CONTENT" == "true" ]] || [[ -z "${line// /}" ]]; then
                    if [[ "$SECTION_HAS_CONTENT" == "true" ]]; then
                        echo "$line"
                    fi
                fi
            fi
        else
            echo "$line"
        fi
    done < "$CHANGELOG"
    
    # Output final pending section if it had content
    if [[ -n "$PENDING_SECTION" ]] && [[ "$SECTION_HAS_CONTENT" == "true" ]]; then
        echo "$PENDING_SECTION"
        echo ""
    fi
} > "$CHANGELOG.tmp"

mv "$CHANGELOG.tmp" "$CHANGELOG"

echo "Marked $VERSION for release on $RELEASE_DATE"
echo "Created new unreleased entry for $NEXT_VERSION"
